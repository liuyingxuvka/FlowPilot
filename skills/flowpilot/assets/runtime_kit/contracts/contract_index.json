{
  "schema_version": "flowpilot.output_contract_registry.v1",
  "authority": "system",
  "controller_visibility": "contract_metadata_only",
  "controller_may_invent_or_rewrite_contracts": false,
  "pm_must_select_contract_before_dispatch": true,
  "role_must_self_check_before_return": true,
  "default_forbidden_envelope_body_fields": [
    "blockers",
    "checks",
    "commands",
    "decision",
    "evidence",
    "findings",
    "passed",
    "recommendations",
    "repair_instructions",
    "report_body",
    "decision_body",
    "result_body"
  ],
  "selection_rules": [
    {
      "task_family": "worker.current_node",
      "packet_type": "work_packet",
      "recipient_roles": [
        "worker_a",
        "worker_b"
      ],
      "contract_id": "flowpilot.output_contract.worker_current_node_result.v1"
    },
    {
      "task_family": "worker.material_scan",
      "packet_type": "material_scan",
      "recipient_roles": [
        "worker_a",
        "worker_b"
      ],
      "contract_id": "flowpilot.output_contract.worker_material_scan_result.v1"
    },
    {
      "task_family": "worker.research",
      "packet_type": "research",
      "recipient_roles": [
        "worker_a",
        "worker_b"
      ],
      "contract_id": "flowpilot.output_contract.worker_research_result.v1"
    },
    {
      "task_family": "reviewer.review",
      "packet_type": "review_request",
      "recipient_roles": [
        "human_like_reviewer"
      ],
      "contract_id": "flowpilot.output_contract.reviewer_review_report.v1"
    },
    {
      "task_family": "officer.model_report",
      "packet_type": "officer_request",
      "recipient_roles": [
        "process_flowguard_officer",
        "product_flowguard_officer"
      ],
      "contract_id": "flowpilot.output_contract.officer_model_report.v1"
    },
    {
      "task_family": "officer.model_miss_report",
      "packet_type": "officer_request",
      "recipient_roles": [
        "process_flowguard_officer",
        "product_flowguard_officer"
      ],
      "contract_id": "flowpilot.output_contract.flowguard_model_miss_report.v1"
    },
    {
      "task_family": "pm.model_miss_triage",
      "packet_type": "role_decision",
      "recipient_roles": [
        "project_manager"
      ],
      "contract_id": "flowpilot.output_contract.pm_model_miss_triage_decision.v1"
    },
    {
      "task_family": "gate.decision",
      "packet_type": "role_decision",
      "recipient_roles": [
        "project_manager",
        "human_like_reviewer",
        "process_flowguard_officer",
        "product_flowguard_officer"
      ],
      "contract_id": "flowpilot.output_contract.gate_decision.v1"
    },
    {
      "task_family": "pm.resume_decision",
      "packet_type": "role_decision",
      "recipient_roles": [
        "project_manager"
      ],
      "contract_id": "flowpilot.output_contract.pm_resume_decision.v1"
    },
    {
      "task_family": "pm.parent_segment_decision",
      "packet_type": "role_decision",
      "recipient_roles": [
        "project_manager"
      ],
      "contract_id": "flowpilot.output_contract.pm_parent_segment_decision.v1"
    },
    {
      "task_family": "pm.closure",
      "packet_type": "role_decision",
      "recipient_roles": [
        "project_manager"
      ],
      "contract_id": "flowpilot.output_contract.pm_terminal_closure_decision.v1"
    }
  ],
  "contracts": [
    {
      "contract_id": "flowpilot.output_contract.role_output_envelope.v1",
      "schema_version": "flowpilot.output_contract.v1",
