      "contract_id": "flowpilot.output_contract.pm_model_miss_triage_decision.v1",
      "schema_version": "flowpilot.output_contract.v1",
      "task_family": "pm.model_miss_triage",
      "recipient_roles": [
        "project_manager"
      ],
      "expected_return_envelope": "role_output_envelope",
      "router_event": "pm_records_model_miss_triage_decision",
      "required_body_fields": [
        "decided_by_role",
        "decision",
        "defect_or_blocker_id",
        "reviewer_block_source_path",
        "model_miss_scope",
        "flowguard_capability",
        "same_class_findings_reviewed",
        "repair_recommendation_reviewed",
        "selected_next_action",
        "why_repair_may_start",
        "blockers",
        "contract_self_check"
      ],
      "required_body_values": {
        "decided_by_role": "project_manager"
      },
      "allowed_decision_values": [
        "request_officer_model_miss_analysis",
        "proceed_with_model_backed_repair",
        "out_of_scope_not_modelable",
        "needs_evidence_before_modeling",
        "stop_for_user"
      ],
      "conditional_required_fields": {
        "decision=proceed_with_model_backed_repair": [
          "flowguard_capability.can_model_bug_class",
          "officer_report_refs",
          "same_class_findings_reviewed",
          "repair_recommendation_reviewed",
          "candidate_repairs_considered",
          "minimal_sufficient_repair_recommendation",
          "post_repair_model_checks_required"
        ],
        "decision=out_of_scope_not_modelable": [
          "flowguard_capability.can_model_bug_class",
          "flowguard_capability.incapability_reason"
        ]
      },
      "router_mechanical_validation": [
        "required_fields_present",
        "allowed_decision_value",
        "model_backed_repair_requires_officer_report_refs",
        "model_backed_repair_requires_same_class_and_minimal_repair_review",
        "out_of_scope_repair_requires_flowguard_incapability_reason",
        "non_authorizing_decisions_do_not_unlock_review_repair"
      ],
      "contract_self_check_required": true
    },
