  "functional_acceptance_matrix": [
    {
      "acceptance_id": "<acceptance-id>",
      "covers_tasks": [],
      "inputs": [],
      "expected_outputs": [],
      "state_transitions": [],
      "permissions_or_roles": [],
      "failure_cases": [],
      "checks": [],
      "evidence_paths": []
