  ],
  "approvals": {
    "project_manager_synthesis_path": "<path-or-null>",
    "product_flowguard_officer_modelability": "<pending|approved|blocked>",
    "product_flowguard_officer_report_path": "<path-or-null>",
    "human_like_reviewer_usefulness_challenge": "<pending|passed|blocked>",
