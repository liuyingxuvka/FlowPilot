    "known_product_context_paths": []
  },
  "user_task_map": [
    {
      "task_id": "<task-id>",
      "user_or_actor": "<user-or-actor>",
      "trigger": "<when-this-task-starts>",
      "goal": "<desired-outcome>",
      "current_gap": "<gap-or-null>",
      "failure_or_recovery_expectations": []
    }
  ],
  "product_capability_map": [
    {
      "capability_id": "<capability-id>",
      "supports_tasks": [],
      "behavior": "<what-the-product-must-do>",
