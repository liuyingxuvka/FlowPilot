{
  "schema_version": "flowpilot.continuation_evidence.v1",
  "run_id": "<run-id>",
  "run_root": ".flowpilot/runs/<run-id>",
  "recorded_at": "<iso-8601-timestamp>",
  "recorded_by_role": "<controller|project_manager|process_flowguard_officer|human_like_reviewer>",
  "host": {
    "host_kind": "<codex_desktop|codex_cli|chatgpt|manual_only|unknown>",
    "supports_real_wakeups": null,
    "supports_automations": null,
    "supports_background_subagents": null,
    "supports_native_plan_tool": null,
    "evidence_sources": []
  },
  "continuation_mode": "<automated|manual-resume|blocked|unknown>",
  "controller_resume_contract": {
    "controller_only": true,
    "stable_launcher": true,
    "controller_visibility": "packet_and_result_envelopes_only",
    "controller_may_read_packet_body": false,
    "controller_may_read_result_body": false,
    "controller_may_execute_worker_packet": false,
    "controller_may_advance_from_own_evidence": false,
    "controller_may_relabel_wrong_role_origin": false,
    "pm_decision_required_after_wakeup": true,
    "pm_controller_reminder_required": true,
    "router_direct_dispatch_required_before_worker": true,
    "reviewer_dispatch_required_before_worker": false,
    "role_reminder_required_in_controller_messages": true,
    "role_echo_required_in_subagent_responses": true
  },
  "packet_resume": {
    "packet_ledger_path": ".flowpilot/runs/<run-id>/packet_ledger.json",
    "active_packet_id": "<packet-id-or-null>",
    "packet_envelope_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_envelope.json",
    "packet_body_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_body.md",
    "result_envelope_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/result_envelope.json",
    "result_body_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/result_body.md",
    "packet_holder": "<PM|Reviewer|WorkerA|WorkerB|Controller|User|null>",
    "status": "<needs-pm-decision|packet-with-reviewer|packet-with-worker|worker-result-needs-pm-disposition|pm-gate-package-with-reviewer|reviewer-decision-needs-pm|ambiguous-blocked|complete>",
    "holder_change_user_status_update_required": true,
    "holder_change_user_status_update_written": false,
    "pm_decision_path": "<pm-decision-evidence-path-or-null>",
    "router_direct_dispatch_path": "<packet-envelope-path#router_direct_dispatch-or-null>",
    "reviewer_dispatch_path": "<legacy-reviewer-dispatch-evidence-path-or-null>",
    "worker_result_path": "<worker-result-envelope-path-or-null>",
    "pm_result_disposition_path": "<pm-package-result-disposition-path-or-null>",
    "pm_formal_gate_package_path": "<pm-built-review-gate-package-path-or-null>",
    "review_decision_path": "<review-decision-path-or-null>",
    "role_origin_audit_path": "<role-origin-audit-evidence-path-or-null>",
    "role_origin_audit_required_before_review_pass": true,
    "physical_packet_files_checked": false,
    "controller_context_body_exclusion_checked": false,
    "packet_envelope_to_role_checked": false,
    "packet_body_hash_checked": false,
    "result_envelope_completed_by_role_checked": false,
    "result_envelope_completed_by_agent_id_checked": false,
    "result_body_hash_checked": false,
    "worker_result_author_role": "<worker_a|worker_b|authorized_non_controller|controller|unknown|null>",
    "worker_result_agent_id": "<agent-id-or-null>",
    "worker_result_author_matches_assignment": false,
    "controller_origin_evidence_blocks_resume": true,
    "controller_body_access_blocks_resume": true,
    "body_hash_mismatch_blocks_resume": true,
    "stale_packet_body_reuse_blocks_resume": true,
    "pm_reissue_or_repair_required_on_role_origin_mismatch": true,
    "next_controller_action": "<ask-pm|send-to-reviewer|send-to-worker|send-worker-result-to-pm|ask-pm-for-result-disposition|send-pm-gate-package-to-reviewer|send-review-to-pm|write-controlled-stop|block>",
    "ambiguous_worker_state_blocks_controller_execution": true,
    "pm_reissue_or_repair_required_when_ambiguous": true
  },
  "automated_continuation": {
    "selected": false,
    "automation_id": "<automation-id-or-null>",
    "rrule": "FREQ=MINUTELY;INTERVAL=1",
    "interval_minutes": 1,
    "health_checked": false,
    "health_evidence_path": "<path-or-null>",
    "unattended_recovery_claim_allowed": false
  },
  "manual_resume": {
    "selected": false,
    "resume_prompt": "continue FlowPilot",
    "resume_notice_path": "<path-or-null>",
    "manual_resume_packet_written": false,
    "reason": "<unsupported-host|user-declined-scheduled-continuation|policy-block|other|null>"
  },
  "blocked": {
    "is_blocked": false,
    "blocker": "<blocker-or-null>",
    "required_user_or_environment_action": "<action-or-null>"
  },
  "state_updates": {
    "state_path": ".flowpilot/runs/<run-id>/state.json",
    "frontier_path": ".flowpilot/runs/<run-id>/execution_frontier.json",
    "heartbeat_path": ".flowpilot/runs/<run-id>/heartbeats/<hb-id>.json",
    "state_continuation_fields_updated": false,
    "frontier_continuation_fields_updated": false,
    "heartbeat_continuation_fields_updated": false
  }
}
