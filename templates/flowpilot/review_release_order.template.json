{
  "schema_version": "flowpilot.review_release_order.v1",
  "run_id": "<run-id>",
  "route_id": "<route-id>",
  "route_version": 0,
  "node_id": "<node-id>",
  "gate_id": "<gate-id>",
  "pm_owned": true,
  "status": "<draft|released|blocked|superseded>",
  "purpose": "Project-manager order that releases the human-like reviewer only after worker output has returned to PM and PM has built the formal current-gate package.",
  "worker_output": {
    "ready_for_review": false,
    "owner_role": "<worker_a|worker_b|authorized_non_controller|other>",
    "actual_result_author_role": "<worker_a|worker_b|authorized_non_controller|controller|unknown>",
    "packet_envelope_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_envelope.json",
    "packet_body_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_body.md",
    "physical_packet_files_written": false,
    "controller_context_body_exclusion_verified": false,
    "packet_controller_relay_signature_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_envelope.json#controller_relay",
    "packet_body_opened_after_controller_relay_check": false,
    "packet_body_hash": "<sha256-of-packet-body-or-null>",
    "result_envelope_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/result_envelope.json",
    "result_body_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/result_body.md",
    "result_body_hash": "<sha256-of-result-body-or-null>",
    "result_controller_relay_signature_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/result_envelope.json#controller_relay",
    "result_body_opened_after_controller_relay_check": false,
    "result_body_opened_by_pm": false,
    "pm_result_disposition_path": "<pm-package-result-disposition-path>",
    "pm_result_disposition": "<absorbed|rework_requested|canceled|blocked|route_or_node_mutation_required>",
    "pm_formal_gate_package_path": "<pm-built-review-gate-package-path>",
    "controller_received_result_envelope_only": true,
    "pm_requires_reviewer_mail_chain_audit": true,
    "pm_requires_reviewer_role_origin_audit": true,
    "pm_requires_reviewer_envelope_body_integrity_audit": true,
    "output_summary": "<summary>",
    "output_paths": [],
    "known_limitations": []
  },
  "release_scope": {
    "reviewer_role": "human_like_reviewer",
    "review_type": "<node_human_review|implementation_review|parent_backward_replay|terminal_backward_replay|other>",
    "review_target": "<artifact-or-product-surface>",
    "required_direct_checks": [],
    "evidence_pointers": [],
    "required_role_origin_checks": [
      "verify PM packet author",
      "verify physical packet/result envelope-body files exist",
      "verify controller handoff/context contained envelope only and no body text",
      "verify packet controller relay signature and no-read/no-execute declaration",
      "verify result controller relay signature and no-read/no-execute declaration",
      "verify PM opened worker result bodies only after relay check",
      "verify reviewer opened only the PM-built formal gate package",
      "verify no private role-to-role packet/result delivery",
      "verify contaminated, rejected, or unopened mail was sent to PM for restart, repair node, or sender reissue",
      "verify router direct-dispatch preflight approval",
      "verify packet envelope to_role",
      "verify packet body hash against packet envelope",
      "verify result envelope completed_by_role",
      "verify result envelope completed_by_agent_id belongs to that role",
      "verify result body hash against result envelope",
      "verify assigned worker identity",
      "verify actual result author",
      "block_invalid_role_origin when actual author is controller or unknown",
      "block body_hash_mismatch or stale_packet_body before pass",
      "forbid cosigning or relabelling wrong-role completion"
    ],
    "completion_report_only_allowed": false,
    "worker_report_only_allowed": false
  },
  "pm_gate": {
    "pm_role": "project_manager",
    "hold_instruction_path": "<path-or-null>",
    "release_reason": "<why-review-can-start>",
    "hard_stops": [],
    "released_at": "<iso-8601-timestamp-or-null>",
    "release_evidence_path": "<path-or-null>"
  },
  "reviewer_acknowledgement": {
    "acknowledged": false,
    "acknowledged_at": "<iso-8601-timestamp-or-null>",
    "reviewer_report_path": "<path-or-null>"
  }
}
