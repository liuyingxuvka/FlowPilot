    "report_only_allowed": false,
    "ordered_replay_segments": [
      {
        "segment_id": "root-acceptance",
        "segment_type": "root_acceptance",
        "source_entries": [],
        "node_acceptance_plan_paths": [],
        "reviewer_manual_checks": [],
        "reviewer_evidence_path": "<path-or-null>",
        "pm_segment_decision": "<continue|repair|route_mutation|pm_stop|not_reviewed>",
        "pm_decision_evidence_path": "<path-or-null>"
      },
      {
        "segment_id": "parent-nodes",
        "segment_type": "parent_or_module_nodes",
        "source_entries": [],
        "local_parent_backward_replay_paths": [],
