  "residual_risk_triage": {
    "path": ".flowpilot/runs/<run-id>/residual_risk_triage.json",
    "required": true,
    "policy": "Completion reports must not carry unresolved residual risks. Every risk-like item is triaged as blocking, test_gap, evidence_gap, route_gap, resolved_issue, non_risk_scope_note, explicit_exception_with_required_approval, or false_positive.",
    "blocking_items_returned_to_route": false,
    "test_gaps_returned_to_qa": false,
    "evidence_gaps_repaired": false,
    "scope_notes_renamed": false,
    "explicit_exceptions_have_required_approval": false,
    "unresolved_residual_risk_count": null
  },
  "generated_resources": [
