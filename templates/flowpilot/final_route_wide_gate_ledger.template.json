        "pm_segment_decision": "<continue|repair|route_mutation|pm_stop|not_reviewed>",
        "pm_decision_evidence_path": "<path-or-null>"
      }
    ],
    "required_segment_checks": {
      "root_acceptance_reviewed": false,
      "parent_nodes_reviewed": false,
      "leaf_nodes_reviewed": false,
      "every_effective_node_replayed_by_reviewer": false,
      "pm_segment_decisions_recorded": false,
      "worker_or_completion_report_only_segments": 0
    },
    "repair_restart_policy": {
      "required": true,
      "recorded": false,
      "default_restart": "restart_from_delivered_product",
      "impacted_ancestor_restart_allowed_only_with_pm_reason": true,
      "repair_invalidates_affected_evidence": true,
      "repair_requires_rebuilt_ledger": true,
      "repair_requires_rerun_reviewer_backward_replay": true,
      "repair_requires_pm_reapproval": true
    },
    "blocking_findings": [],
    "passed": false
  },
  "reviewer_backward_check": {
    "required": true,
    "status": "not_started",
    "reviewer_role": "human_like_reviewer",
    "evidence_path": "<path-or-null>",
    "must_use_terminal_human_backward_replay": true,
    "requires_delivered_product_start": true,
    "requires_pm_segment_decisions": true,
    "requires_repair_restart_policy": true
  },
  "pm_completion_approval": {
    "status": "not_started",
    "requires_unresolved_count_zero": true,
    "requires_reviewer_backward_check": true,
    "requires_independent_adversarial_audit": true,
    "completion_report_only_allowed": false,
    "approval_evidence_path": "<path-or-null>",
    "independent_validation_evidence_path": "<path-or-null>",
