        "applies_when_node_has_children": "<true|false>",
        "parent_backward_replay_path": "<path-or-null>",
        "structural_trigger_confirmed": "<true|false>",
        "reviewer_started_from_parent_delivered_result": "<true|false>",
        "pm_segment_decision_recorded": "<true|false>",
        "same_parent_replay_rerun_after_latest_repair": "<true|false>"
      },
      "superseded_by": "<node-or-gate-id-or-null>",
      "superseded_reason": "<reason-or-null>",
      "waiver_reason": "<reason-or-null>",
      "unresolved_reason": "<reason-or-null>"
