      "stale_or_superseded_evidence_checked": false,
      "waiver_authority_checked": false,
      "unresolved_counts_checked": false,
      "reviewer_replay_checked": false,
      "blockers_and_downstream_consequences_checked": false,
      "frozen_user_goal_consistency_checked": false,
