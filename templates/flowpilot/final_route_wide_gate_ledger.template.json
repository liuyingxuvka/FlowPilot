      "resource_id": "<resource-id>",
      "resource_type": "<imagegen_concept|visual_asset|screenshot|route_diagram|model_report|other>",
      "created_by_gate": "<node-or-gate-id>",
      "created_path": "<path-or-null>",
      "disposition": "<consumed_by_implementation|included_in_final_output|qa_evidence|flowguard_evidence|user_flow_diagram|superseded|quarantined|discarded_with_reason>",
      "consumed_by": [
        "<node-gate-report-or-output-id>"
      ],
      "superseded_by": "<resource-id-or-null>",
      "discard_reason": "<reason-or-null>",
      "unresolved_reason": "<reason-or-null>"
    }
  ],
  "generated_resource_ledger": {
    "path": ".flowpilot/runs/<run-id>/generated_resource_ledger.json",
