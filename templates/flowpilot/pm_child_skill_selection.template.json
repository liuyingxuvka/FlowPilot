{
  "artifact_type": "flowpilot_pm_child_skill_selection",
  "schema_version": 1,
  "created_at": "<iso-8601-timestamp>",
  "run_id": "<run-id>",
  "owner": "project_manager",
  "status": "draft",
  "source_inputs": {
    "product_function_architecture_path": ".flowpilot/runs/<run-id>/product_function_architecture.json",
    "capabilities_manifest_path": ".flowpilot/runs/<run-id>/capabilities.json",
    "local_skill_inventory_path": ".flowpilot/runs/<run-id>/local_skill_inventory.json",
    "frozen_contract_path": ".flowpilot/runs/<run-id>/contract.md"
  },
  "selection_rule": "Product capability needs and FlowPilot process needs choose skills. Local skill availability alone never creates route work.",
  "selection_dimensions": {
    "deliverable_support": "Does the skill help produce, validate, or inspect the user-visible deliverable?",
    "process_support": "Does the skill help PM, reviewer, officer, worker, or follow-up roles perform FlowPilot planning, modeling, review, validation, or evidence work?",
    "raw_availability_is_not_a_reason": true
  },
  "minimum_sufficient_complexity_rule": {
    "principle": "A child skill is required only when it closes a product, verification, safety, or workflow gap that the simpler main route cannot reliably close.",
    "raw_availability_is_not_a_reason": true,
    "deferred_or_rejected_is_valid_high_quality_decision": true
  },
  "skill_decisions": [
    {
      "skill_name": "<skill-name>",
      "decision": "<required|conditional|deferred|rejected>",
      "decision_reason": "<why this follows from deliverable-support or process-support need>",
      "support_dimensions": {
        "deliverable_support": "<required|conditional|not_applicable>",
        "process_support": "<required|conditional|not_applicable>"
      },
      "supported_product_capabilities": [],
      "supported_flowpilot_process_contexts": [
        "<pm_planning|pm_route_design|pm_acceptance_writing|worker_execution|reviewer_review|process_officer_modeling|product_officer_modeling|validation|followup>"
      ],
      "role_skill_use_candidates": [
        {
          "used_by_role": "<project_manager|human_like_reviewer|process_flowguard_officer|product_flowguard_officer|worker_a|worker_b|followup_officer>",
          "use_context": "<planning|route_design|acceptance_writing|execution|review|modeling|validation|followup>",
          "candidate_output_or_gate": "<affected-output-or-gate-id>",
          "evidence_required": true
        }
      ],
      "simpler_path_without_skill": "<viable|not_viable|unknown>",
      "why_skill_complexity_is_justified": "<product-verification-safety-or-workflow-benefit-or-null>",
      "trigger_condition": "<when conditional or deferred becomes active>",
      "hard_gates_or_user_approval_needed": [],
      "route_inclusion": "<initial_route|current_node_only|defer_until_trigger|exclude>",
      "skill_file_to_load": "<path-to-SKILL.md-or-null>",
      "references_to_load_now": [],
      "references_deferred_with_reason": [],
      "selection_evidence": []
    }
  ],
  "negative_selection": [
    {
      "skill_name": "<available-but-not-used-skill>",
      "reason": "<not-needed-for-product|unsafe-without-user-approval|out-of-scope|defer-until-trigger>",
      "revisit_condition": "<condition-or-null>"
    }
  ],
  "next_artifact": ".flowpilot/runs/<run-id>/child_skill_gate_manifest.json",
  "approval": {
    "pm_decision_recorded": true,
    "raw_inventory_used_as_authority": false,
    "controller_self_approval_allowed": false,
    "worker_approval_allowed": false
  }
}
