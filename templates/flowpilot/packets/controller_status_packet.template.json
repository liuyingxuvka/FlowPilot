{
  "schema_version": "flowpilot.controller_status_packet.v1",
  "run_id": "<run-id>",
  "route_id": "<route-id>",
  "route_version": 0,
  "node_id": "<node-id>",
  "packet_id": "<packet-id-or-null>",
  "updated_at": "<iso-8601-timestamp>",
  "controller_role": "controller",
  "status_scope": "envelope_holder_and_display_only",
  "packet_holder": "<PM|Reviewer|WorkerA|WorkerB|ProcessFlowGuardOfficer|ProductFlowGuardOfficer|Controller|User|null>",
  "packet_status": "<needs-pm-decision|envelope-with-controller|envelope-with-target-role|result-envelope-with-controller|reviewer-decision-needs-pm|blocked|complete>",
  "next_expected_event": "<pm_decision|reviewer_dispatch|worker_result_envelope|reviewer_decision|pm_reissue|user_input|completion>",
  "holder_changed": false,
  "holder_change_user_status_update_written": false,
  "cockpit_available": false,
  "major_node_entered": false,
  "chat_mermaid_required_when_cockpit_missing": true,
  "chat_mermaid_displayed": false,
  "controller_allowed_actions": [
    "read_envelope",
    "relay_envelope",
    "update_holder_status",
    "display_required_mermaid",
    "request_pm_decision",
    "wait_for_role_return"
  ],
  "controller_forbidden_actions": [
    "read_body",
    "execute_body",
    "implement_worker_scope",
    "produce_gate_evidence",
    "approve_gate",
    "close_node"
  ],
  "evidence_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/controller_status_packet.json"
}
