{
  "schema_version": "flowpilot.packet_envelope.v1",
  "packet_id": "<packet-id>",
  "packet_type": "<user_intake|work_packet|review_request|officer_request|pm_decision>",
  "run_id": "<run-id>",
  "route_id": "<route-id>",
  "route_version": 0,
  "node_id": "<node-id>",
  "is_current_node": true,
  "created_at": "<iso-8601-timestamp>",
  "from_role": "project_manager",
  "to_role": "<worker_a|worker_b|human_like_reviewer|process_flowguard_officer|product_flowguard_officer|project_manager>",
  "output_contract_id": "<packet-envelope-output_contract.contract_id>",
  "batch_membership": {
    "batch_id": "<batch-id-or-null>",
    "batch_kind": "<material_scan|research|current_node|pm_role_work|null>",
    "join_policy": "<all_results_before_pm_absorption|all_results_before_review>",
    "dependency_class": "<blocking|advisory|prep-only>",
    "blocks_gate_ids": [],
    "router_tracks_member_status": true,
    "partial_batch_status_is_metadata_only": true
  },
  "active_holder_return_path": {
    "lease_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/active_holder_lease.json",
    "events_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/active_holder_events.jsonl",
    "use_when_router_issues_lease": true,
    "fallback_to_controller_relay_when_no_live_agent": true
  },
  "output_contract": {
    "schema_version": "flowpilot.output_contract.v1",
    "contract_id": "<system-registry-contract-id>",
    "selected_by_role": "project_manager",
    "recipient_role": "<same-as-to_role>",
    "task_family": "<task-family>",
    "node_id": "<node-id>",
    "required_result_body_sections": [
      "Status",
      "Evidence",
      "Open Issues",
      "Contract Self-Check"
    ],
    "required_result_envelope_fields": [
      "completed_by_role",
      "completed_by_agent_id",
      "result_body_path",
      "result_body_hash",
      "next_recipient",
      "body_visibility"
    ],
    "contract_self_check_required": true,
    "reviewer_must_block_missing_or_failed_check": true,
    "registry_path": "runtime_kit/contracts/contract_index.json"
  },
  "return_to": "controller",
  "next_holder": "<Controller|WorkerA|WorkerB|Reviewer|ProcessFlowGuardOfficer|ProductFlowGuardOfficer|PM>",
  "body_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_body.md",
  "body_hash": "<sha256-of-packet-body>",
  "body_hash_algorithm": "sha256",
  "identity_boundary": {
    "schema_version": "flowpilot.packet_identity_boundary.v1",
    "marker": "FLOWPILOT_PACKET_IDENTITY_BOUNDARY_V1",
    "recipient_role": "<same-as-to_role>",
    "required": true
  },
  "body_visibility": "<sealed_target_role_only|external_user_input_controller_visible>",
  "replacement_for": null,
  "supersedes": [],
  "stale_after_route_version": 0,
  "controller_visibility": "envelope_only",
  "controller_relay": {
    "schema_version": "flowpilot.controller_relay.v1",
    "delivered_via_controller": true,
    "controller_agent_id": "<controller-agent-id>",
    "received_from_role": "<from_role>",
    "relayed_to_role": "<to_role>",
    "received_at": "<iso-8601-timestamp>",
    "relayed_at": "<iso-8601-timestamp>",
    "envelope_hash": "<sha256-stable-envelope-hash>",
    "body_was_read_by_controller": false,
    "body_was_executed_by_controller": false,
    "body_visibility": "<sealed_target_role_only|external_user_input_controller_visible>",
    "external_user_input_visible_to_controller": false,
    "holder_before": "<from_role>",
    "holder_after": "<to_role>",
    "private_role_to_role_delivery_detected": false,
    "recipient_must_verify_before_body_open": true,
    "mutual_role_reminder": {
      "schema_version": "flowpilot.mutual_role_reminder.v1",
      "controller_reminder": "You are Controller only. Relay and record this packet_envelope; do not open, summarize, execute, approve gates, mutate routes, close nodes, or issue free-text work instructions.",
      "sender_reminder": "The sender/producer for this envelope is `<from_role>`.",
      "recipient_reminder": "The recipient is `<to_role>` for this envelope only. Open the body only after verifying Controller relay, role target, and hash; act only inside the addressed role and packet/result scope.",
      "reply_continuation_reminder": "When returning or relaying the next envelope, include this same visible mutual-role reminder so Controller and the next recipient are reminded again.",
      "body_boundary_reminder": "Keep sealed body content out of Controller-visible chat; submit envelope metadata to Router."
    },
    "reply_continuation_reminder": "When returning or relaying the next envelope, include this same visible mutual-role reminder so Controller and the next recipient are reminded again.",
    "recipient_role_reminder": "This mail is for `<to_role>` only.",
    "mail_only_reminder": "The recipient must answer through a file-backed packet/result/report body and submit the runtime envelope to Router; Controller sees only Router-authorized metadata.",
    "chat_response_body_allowed": false
  },
  "controller_relay_history": [],
  "body_opened_by_role": {
    "role": "<to_role-or-null>",
    "opened_at": "<iso-8601-timestamp-or-null>",
    "controller_relay_verified": false,
    "body_hash_verified": false
  },
  "controller_allowed_actions": [
    "read_packet_envelope",
    "update_packet_holder_and_status",
    "relay_envelope_to_to_role",
    "display_chat_mermaid_when_required",
    "emit_holder_change_status_update",
    "wait_for_role_return",
    "return_envelope_to_pm_on_blocker"
  ],
  "controller_forbidden_actions": [
    "read_packet_body",
    "edit_packet_body",
    "execute_packet_body",
    "implement_worker_scope",
    "generate_worker_artifacts",
    "run_product_validation_for_worker_scope",
    "approve_gate",
    "close_node",
    "change_to_role",
    "rewrite_body_hash",
    "relabel_wrong_role_origin"
  ],
  "body_access": {
    "target_role_only": true,
    "allowed_reader_roles": [
      "<same-as-to_role>"
    ],
    "controller_can_read_body": false,
    "reviewer_can_read_body_only_when_packet_addressed_to_reviewer": true,
    "reviewer_reviews_pm_formal_gate_package_after_result_disposition": true,
    "pm_can_read_worker_result_body_for_disposition": true,
    "recipient_must_verify_controller_relay_before_body_open": true
  },
  "integrity_policy": {
    "body_hash_required": true,
    "body_hash_mismatch_blocks_dispatch": true,
    "stale_body_after_route_mutation_blocks_dispatch": true,
    "wrong_holder_blocks_dispatch": true,
    "missing_controller_relay_signature_blocks_body_open": true,
    "controller_read_or_execute_body_requires_sender_reissue": true,
    "private_role_to_role_delivery_blocks_body_open": true
  },
  "barrier_bundle": {
    "schema_version": "flowpilot.barrier_bundle.v1",
    "bundle_id": "<bundle-id-or-null>",
    "barrier_id": "<barrier-id-or-null>",
    "equivalence_mode": "preserve_existing_packet_semantics",
    "member_packet_ids": [
      "<packet-id>"
    ],
    "metadata_only": true,
    "preserves_packet_body_isolation": true,
    "controller_may_read_or_summarize_bundled_bodies": false,
    "controller_may_approve_bundled_gates": false
  },
  "startup_user_intake_policy": {
    "applies_when_packet_type_is_user_intake": true,
    "body_visibility_exception": "external_user_input_controller_visible",
    "controller_bootstrap_scope_only": true,
    "pm_must_request_startup_reviewer_gate_before_opening_start_gate": true
  }
}
