{
  "schema_version": "flowpilot.result_envelope.v1",
  "packet_id": "<packet-id>",
  "packet_type": "result",
  "run_id": "<run-id>",
  "route_id": "<route-id>",
  "route_version": 0,
  "node_id": "<node-id>",
  "source_packet_envelope_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/packet_envelope.json",
  "completed_at": "<iso-8601-timestamp>",
  "completed_by_role": "<worker_a|worker_b|human_like_reviewer|process_flowguard_officer|product_flowguard_officer|project_manager>",
  "completed_by_agent_id": "<agent-id-or-single-agent-role-continuity-id>",
  "expected_role_from_packet_envelope": "<packet-envelope-to_role>",
  "completed_role_matches_packet_to_role": false,
  "completed_agent_id_belongs_to_role": false,
  "result_body_path": ".flowpilot/runs/<run-id>/packets/<packet-id>/result_body.md",
  "result_body_hash": "<sha256-of-result-body>",
  "result_body_hash_algorithm": "sha256",
  "source_output_contract_id": "<packet-envelope-output_contract.contract_id>",
  "output_contract": {
    "schema_version": "flowpilot.output_contract.v1",
    "contract_id": "<same-as-source_output_contract_id>",
    "selected_by_role": "project_manager",
    "recipient_role": "<source-packet-envelope-to_role>",
    "contract_self_check_required": true
  },
  "contract_self_check": {
    "required": true,
    "source_output_contract_id": "<packet-envelope-output_contract.contract_id>",
    "result_body_section": "Contract Self-Check",
    "completed": false,
    "passed": false
  },
  "identity_boundary": {
    "schema_version": "flowpilot.result_identity_boundary.v1",
    "marker": "FLOWPILOT_RESULT_IDENTITY_BOUNDARY_V1",
    "completed_by_role": "<same-as-completed_by_role>",
    "required": true
  },
  "next_recipient": "<human_like_reviewer|project_manager|process_flowguard_officer|product_flowguard_officer>",
  "return_to": "controller",
  "next_holder": "<human_like_reviewer|project_manager|process_flowguard_officer|product_flowguard_officer>",
  "body_visibility": "sealed_target_role_only",
  "controller_visibility": "envelope_only",
  "controller_relay": {
    "schema_version": "flowpilot.controller_relay.v1",
    "delivered_via_controller": true,
    "controller_agent_id": "<controller-agent-id>",
    "received_from_role": "<completed_by_role>",
    "relayed_to_role": "<next_recipient>",
    "received_at": "<iso-8601-timestamp>",
    "relayed_at": "<iso-8601-timestamp>",
    "envelope_hash": "<sha256-stable-result-envelope-hash>",
    "body_was_read_by_controller": false,
    "body_was_executed_by_controller": false,
    "body_visibility": "sealed_target_role_only",
    "external_user_input_visible_to_controller": false,
    "holder_before": "<completed_by_role>",
    "holder_after": "<next_recipient>",
    "private_role_to_role_delivery_detected": false,
    "recipient_must_verify_before_body_open": true,
    "mutual_role_reminder": {
      "schema_version": "flowpilot.mutual_role_reminder.v1",
      "controller_reminder": "You are Controller only. Relay and record this result_envelope; do not open, summarize, execute, approve gates, mutate routes, close nodes, or issue free-text work instructions.",
      "sender_reminder": "The sender/producer for this envelope is `<completed_by_role>`.",
      "recipient_reminder": "The recipient is `<next_recipient>` for this envelope only. Open the body only after verifying Controller relay, role target, and hash; act only inside the addressed role and packet/result scope.",
      "reply_continuation_reminder": "When returning or relaying the next envelope, include this same visible mutual-role reminder so Controller and the next recipient are reminded again.",
      "body_boundary_reminder": "Keep sealed body content out of Controller-visible chat; return envelope metadata only."
    },
    "reply_continuation_reminder": "When returning or relaying the next envelope, include this same visible mutual-role reminder so Controller and the next recipient are reminded again.",
    "recipient_role_reminder": "This mail is for `<next_recipient>` only.",
    "mail_only_reminder": "The recipient must answer through a file-backed packet/result/report body and return only an envelope to Controller.",
    "chat_response_body_allowed": false
  },
  "controller_relay_history": [],
  "result_body_opened_by_role": {
    "role": "<next_recipient-or-null>",
    "opened_at": "<iso-8601-timestamp-or-null>",
    "controller_relay_verified": false,
    "body_hash_verified": false
  },
  "controller_allowed_actions": [
    "read_result_envelope",
    "update_packet_holder_and_status",
    "relay_result_envelope_to_next_recipient",
    "emit_holder_change_status_update",
    "wait_for_next_role_return",
    "ask_pm_for_repair_or_next_packet_on_blocker"
  ],
  "controller_forbidden_actions": [
    "read_result_body",
    "edit_result_body",
    "execute_result_body",
    "add_missing_evidence",
    "run_product_validation_for_worker_scope",
    "approve_gate",
    "close_node",
    "rewrite_completed_by_role",
    "rewrite_completed_by_agent_id",
    "relabel_wrong_role_origin",
    "recompute_body_hash_to_hide_mismatch"
  ],
  "origin_policy": {
    "controller_origin_artifact": false,
    "wrong_role_completion_blocks_review_pass": true,
    "wrong_role_completion_may_not_be_cosigned": true,
    "wrong_role_completion_may_not_be_relabelled": true,
    "pm_reissue_required_on_mismatch": true
  },
  "integrity_policy": {
    "result_body_hash_required": true,
    "result_body_hash_mismatch_blocks_review_pass": true,
    "stale_result_body_after_route_mutation_blocks_review_pass": true,
    "missing_controller_relay_signature_blocks_body_open": true,
    "controller_read_or_execute_body_requires_sender_reissue": true,
    "private_role_to_role_delivery_blocks_body_open": true
  },
  "barrier_bundle": {
    "schema_version": "flowpilot.barrier_bundle.v1",
    "bundle_id": "<bundle-id-or-null>",
    "barrier_id": "<barrier-id-or-null>",
    "equivalence_mode": "preserve_existing_packet_semantics",
    "member_packet_ids": [
      "<packet-id>"
    ],
    "metadata_only": true,
    "preserves_result_body_isolation": true,
    "controller_may_read_or_summarize_bundled_bodies": false,
    "controller_may_approve_bundled_gates": false
  }
}
