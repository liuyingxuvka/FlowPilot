{
  "schema_version": "flowpilot.flowguard_modeling_request.v1",
  "request_id": "<request-id>",
  "route_id": "<route-id>",
  "node_id": "<node-id-or-null>",
  "created_at": "<iso-8601-timestamp>",
  "created_by_role_key": "project_manager",
  "dispatch_mode": "flowguard_operator_owned_async",
  "flowguard_operator_output_root": ".flowpilot/runs/<run-id>/flowguard_operator_runs/<request-id>/",
  "flowguard_capability_snapshot_path": ".flowpilot/runs/<run-id>/flowguard/capability_snapshot.json",
  "pm_modeling_plan_path": ".flowpilot/runs/<run-id>/flowguard/<product-or-process>_modeling_plan.json",
  "assigned_flowguard_operator_role_keys": [
    "<flowguard_operator>"
  ],
  "controller_coordination": {
    "allowed": true,
    "allowed_scope": [
      "read-only status reconciliation",
      "dependency inventory routing",
      "relaying already-authorized packets",
      "requesting corrected role evidence"
    ],
    "blocked_scope_until_flowguard_operator_reports": [
      "implementation protected by this model gate",
      "route freeze or route advance protected by this model gate",
      "checkpoint or completion closure protected by this model gate",
      "claiming model approval from controller command output"
    ]
  },
  "decision_to_make": "<what PM must decide after the report>",
  "uncertainty": "<what is not known yet>",
  "modeling_scope": "<process|product|target_realization|object|reference_system|migration_equivalence|experiment_derived_behavior|combined>",
  "target_realization_context": {
    "enabled": false,
    "pm_implementation_intent_path": ".flowpilot/runs/<run-id>/implementation_intent/pm_implementation_intent.json",
    "product_behavior_model_path": ".flowpilot/runs/<run-id>/flowguard/product_behavior_model.json",
    "product_behavior_model_pm_decision_path": ".flowpilot/runs/<run-id>/flowguard/product_behavior_model_pm_decision.json",
    "required_output_path": ".flowpilot/runs/<run-id>/flowguard/target_realization_model.json",
    "preserve_pm_intent": true,
    "model_realization_obligations": true,
    "model_thin_success_traps": true,
    "model_evidence_gates": true,
    "forbidden_downgrade": true
  },
  "model_family_scope": {
    "family_ids": [],
    "family_types": [
      "<product_behavior|ui_interaction|data_state|failure_recovery|route_hierarchy|serial_execution|child_skill_conformance|validation_evidence|terminal_closure>"
    ],
    "single_model_allowed_only_with_pm_merge_reason": true,
    "manifest_only_model_family_coverage_forbidden": true
  },
  "reference_system_or_object": {
    "present": false,
    "name": "<source-system-object-or-reference-behavior>",
    "source_behavior_summary": "<observed workflow, state transitions, inputs, outputs, or invariants to model>",
    "target_behavior_summary": "<target workflow, migration behavior, or equivalence expectation>",
    "equivalence_question": "<what must remain equivalent or intentionally diverge>"
  },
  "candidate_options": [
    {
      "id": "<option-id>",
      "summary": "<candidate route, hypothesis, feature, or structure>"
    }
  ],
  "candidate_generation_needed": false,
  "evidence_sources": [
    {
      "path_or_ref": "<path-url-or-observation>",
      "authority": "<user|repo|runtime|screenshot|sample|unknown>",
      "freshness": "<known|stale|unknown>",
      "note": "<why this source matters>"
    }
  ],
  "experiment_requests_allowed_before_modeling": [
    "<bounded command, fixture, sample trace, source run, or inspection needed to make the modelable behavior concrete>"
  ],
  "required_answer_shape": {
    "modelability_result": "<modelable|needs_evidence|needs_split|blocked>",
    "must_include": [
      "model_author_role",
      "model_runner_role",
      "model_interpreter_role",
      "commands_run_by_flowguard_operator",
      "model coverage",
      "blindspots",
      "failure paths",
      "risk tiers for PM",
      "model-derived review agenda",
      "target-realization obligations when modeling_scope=target_realization",
      "toolchain or model improvement suggestions",
      "human walkthrough recommendations",
      "PM decision options",
      "confidence boundary without absolute no-risk wording",
      "recommendation",
      "next smallest executable action"
    ]
  },
  "current_route_effect_if_blocked": "<add evidence node|split request|record blocker>"
}
