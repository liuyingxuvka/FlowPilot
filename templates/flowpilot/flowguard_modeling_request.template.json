{
  "schema_version": "flowpilot.flowguard_modeling_request.v1",
  "request_id": "<request-id>",
  "route_id": "<route-id>",
  "node_id": "<node-id-or-null>",
  "created_at": "<iso-8601-timestamp>",
  "created_by_role_key": "project_manager",
  "assigned_officer_role_keys": [
    "<process_flowguard_officer|product_flowguard_officer>"
  ],
  "decision_to_make": "<what PM must decide after the report>",
  "uncertainty": "<what is not known yet>",
  "modeling_scope": "<process|product|object|combined>",
  "candidate_options": [
    {
      "id": "<option-id>",
      "summary": "<candidate route, hypothesis, feature, or structure>"
    }
  ],
  "candidate_generation_needed": false,
  "evidence_sources": [
    {
      "path_or_ref": "<path-url-or-observation>",
      "authority": "<user|repo|runtime|screenshot|sample|unknown>",
      "freshness": "<known|stale|unknown>",
      "note": "<why this source matters>"
    }
  ],
  "required_answer_shape": {
    "modelability_result": "<modelable|needs_evidence|needs_split|blocked>",
    "must_include": [
      "model coverage",
      "blindspots",
      "failure paths",
      "recommendation",
      "next smallest executable action"
    ]
  },
  "current_route_effect_if_blocked": "<add evidence node|split request|record blocker>"
}
